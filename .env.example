# CourseVision Environment Variables Configuration

# --- Required Variables ---

# Your Telegram Bot API Token, obtained from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# The numeric Telegram User ID authorized to use the bot's management commands
# You can find your ID using bots like @userinfobot
AUTHORIZED_USER_ID=123456789

# Your Google Gemini API Key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# --- Optional Variables ---

# A comma-separated list of additional Telegram user IDs allowed to use the bot
ALLOWED_TELEGRAM_IDS=987654321,112233445

# Path to the SQLite database file (default: database.db)
# If using Docker, this should match the path inside the container (e.g., /data/database.db)
DATABASE_PATH=database.db

# Preferred Gemini model for extraction (e.g., gemini-2.0-flash, gemini-2.5-flash)
GEMINI_MODEL=gemini-2.0-flash

# Timezone for date calculations (default: UTC)
# Example: America/Sao_Paulo
TIMEZONE=UTC

# Path to the responses.json file (default: core/responses.json)
RESPONSES_PATH=core/responses.json
